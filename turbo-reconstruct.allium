-- allium: 3
-- turbo-reconstruct.allium
--
-- Scope: Reconstruct dequantized values from codebook indices.
-- Source: ggml-turbo-kv.c dequantize_block_turbo_kv_4b step 1-2 (line 307-331)
--
-- For each block, unpack 4-bit indices from mse_indices, look up
-- codebook[idx] * scale (where scale = 1/inv_std), producing rotated[] values.
-- Referenced by DequantizeBlock rule in turbo-kv-4b.allium.

entity Codebook {
    entries: Set<Decimal>
    size: Integer
}

entity QuantizedBlock {
    indices: Set<Integer>
    count: Integer
    inv_std: Decimal
}

rule reconstruct_codebook {
    when: reconstruct_codebook(block, codebook)

    requires: codebook.size > 0
    requires: block.count > 0

    let scale = 1.0 / block.inv_std
    let lut = scaled_codebook(codebook.entries, scale)
    let result = lookup_indices(block.indices, lut, block.count)

    ensures: result.count = block.count
}

deferred scaled_codebook -- see: ggml-turbo-kv.c dequantize_block_turbo_kv_4b (codebook * scale)
deferred lookup_indices -- see: ggml-turbo-kv.c dequantize_block_turbo_kv_4b (bit unpack + codebook lookup)
