-- allium: 3
-- turbo-normalize.allium
--
-- Scope: Normalize a vector to unit length.
-- Source: ggml-turbo-kv.c quantize_block_turbo_kv_4b step 2 (line 254-262)
--
-- dst[i] = src[i] / norm.
-- Referenced by QuantizeBlock rule in turbo-kv-4b.allium.

rule normalize {
    when: normalize(data, norm)

    let inv_norm = 1.0 / norm
    let result = scaled(data, inv_norm)

    ensures: L2_norm(result) = 1.0
}

deferred scaled -- black box: element-wise multiplication by 1/norm
