-- allium: 3
-- turbo-rht.allium
--
-- Scope: Randomized Hadamard Transform (RHT) — forward and inverse.
-- Source: ggml-turbo-kv.c turbo_kv_rht_forward / turbo_kv_rht_inverse (lines 154-217)
--
-- RHT applies three steps:
--   1. Sign flip via Knuth multiplicative hash (seed ^ idx) * 2654435761
--   2. Unnormalized Walsh-Hadamard butterfly O(n log n)
--   3. Scale by 1/sqrt(n2) where n2 = floor_pow2(n)
-- Inverse reverses the order: scale, Hadamard, then same sign flip.

entity Vector {
    data: Set<Decimal>
    length: Integer
}

config {
    seed: Integer = 305419896
}

rule RHT_forward {
    when: RHT_forward(data, n, seed)

    requires: n > 0

    let n2 = floor_pow2(n)
    let with_signs = apply_sign_flip(data, n2, seed)
    let hadamarded = walsh_hadamard_transform(with_signs, n2)
    let result = scale(hadamarded, 1.0 / sqrt(n2), n2)

    ensures: Vector.created(
        data: result,
        length: n
    )
}

rule RHT_inverse {
    when: RHT_inverse(data, n, seed)

    requires: n > 0

    let n2 = floor_pow2(n)
    let scaled = scale(data, 1.0 / sqrt(n2), n2)
    let hadamarded = walsh_hadamard_transform(scaled, n2)
    let result = apply_sign_flip(hadamarded, n2, seed)

    ensures: Vector.created(
        data: result,
        length: n
    )
}

invariant RHT_is_orthogonal {
    for a in Vectors:
        for b in Vectors:
            for seed in Seeds:
                let a_rot = RHT_forward(a.data, a.length, seed)
                let b_rot = RHT_forward(b.data, b.length, seed)
                dot_product(a_rot.data, b_rot.data) = dot_product(a.data, b.data)
}

invariant RHT_is_self_inverse {
    for v in Vectors:
        for seed in Seeds:
            let rotated = RHT_forward(v.data, v.length, seed)
            let restored = RHT_inverse(rotated.data, rotated.length, seed)
            restored.data = v.data
}

deferred floor_pow2       -- see: ggml-turbo-kv.c turbo_kv_pow2_floor
deferred apply_sign_flip  -- see: ggml-turbo-kv.c turbo_kv_random_sign
deferred walsh_hadamard_transform -- see: ggml-turbo-kv.c walsh_hadamard
deferred scale            -- black box: element-wise multiplication by scalar
deferred dot_product      -- black box: sum of element-wise products
