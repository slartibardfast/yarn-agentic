-- allium: 3
-- specs/cuda-native-dispatch/calibrated_op_equivalence.allium
--
-- Status: LIVE as of PHASE_CUDA_NATIVE_DISPATCH commit C11 (combined
-- with C8/C9/C10).
--
-- Scope: for every calibrated op registered with the framework, the
-- default and alt strategies produce numerically equivalent output
-- (byte-identical OR fp16/fp32 ULP-bound, per the op's specific
-- contract). The dispatch decision (which strategy fires at a given
-- payload size) may vary across hardware via calibration, but the
-- OUTPUT BITS MUST NOT vary across strategy choice for a fixed input.
--
-- C8-C11 implementation strategy on xeon: all four ops register
-- `default_wins_stub` probes that bias the conservative crossover to
-- never fire (alt.p95 = 10.5 ms vs default.p50 = 1.0 ms). The
-- framework records SIZE_MAX for every op; the alt path never fires
-- in production. The equivalence property is therefore VACUOUS on
-- xeon: there is no alt-strategy output to compare against.
--
-- When a future deployment replaces a stub with a real probe (e.g.
-- C9 re-enables NCCL via the typo fix at ggml-cuda.cu:4449 and ships
-- a real ncclAllReduce-vs-memcpy_peer probe), the equivalence test
-- for that op must be replaced with a real comparison test that
-- runs both strategies at a calibrated payload size and asserts
-- output equivalence (numeric tolerance per dtype).
--
-- Code refs:
--   ik_llama.cpp/ggml/src/ggml-cuda/op_calibration_probes.cu (C8-C11)
--   ik_llama.cpp/ggml/include/ggml-cuda-calibration.h
--   ik_llama.cpp/tests/test-calibration-ops-registered.cpp

allium 3

-- ============================================================
-- Entities
-- ============================================================

entity CalibratedOpStrategy {
    -- One side of a calibrated op (default OR alt).
    op_id:       OpId,
    is_alt:      bool,
}

entity CalibratedOpRun {
    -- One invocation of a calibrated op at a given payload size.
    op_id:         OpId,
    payload_bytes: u64,
    strategy:      CalibratedOpStrategy,
    output_hash:   u64,
}

-- ============================================================
-- Contracts
-- ============================================================

contract AllFourCalibratedOpsRegistered {
    -- After ggml-cuda module load, ggml_cal_op_name(...) returns the
    -- canonical string for every op id. This binds that C8-C11's
    -- static-initializer in op_calibration_probes.cu ran and the
    -- registry has entries for all four ops.
    forall op_id: OpId where op_id in {REDUCE_CROSS_DEVICE,
                                       MATMUL_STREAM_SPLIT,
                                       PEER_COPY,
                                       GRAPH_CAPTURE}:
        ggml_cal_op_name(op_id) is not_null and
        ggml_cal_op_name(op_id) is not_equal_to default_name
}

contract DefaultAndAltOutputEquivalence {
    -- For every (op_id, payload) where both strategies are reachable
    -- (alt threshold <= payload < SIZE_MAX), the output bits MUST be
    -- equivalent. Numeric tolerance depends on dtype:
    --   F32 / FP16 / BF16: ULP-bound per the op's dtype contract
    --   Q8_0: byte-identical
    --
    -- VACUOUS on xeon: all four stubs return SIZE_MAX. The contract
    -- binds on any future deployment that replaces a stub with a
    -- real probe.
    forall op_id: OpId, payload: u64, run_default: CalibratedOpRun, run_alt: CalibratedOpRun
        where run_default.op_id == op_id
        and run_alt.op_id == op_id
        and run_default.payload_bytes == payload
        and run_alt.payload_bytes == payload
        and not run_default.strategy.is_alt
        and run_alt.strategy.is_alt
        and ggml_cuda_threshold_for(op_id) <= payload
        and ggml_cuda_threshold_for(op_id) < SIZE_MAX:
        run_default.output_hash == run_alt.output_hash
}

contract DispatchIsPureFunctionOfThreshold {
    -- For a fixed (op_id, payload, threshold), the strategy chosen at
    -- a calibrated op dispatch site is a pure function of those three
    -- inputs. No hidden state, no time-varying inputs. Restated from
    -- calibrated_dispatch_framework.allium for composition.
    forall op_id: OpId, payload: u64:
        ggml_cuda_use_alt_strategy(op_id, payload) ==
        (payload >= ggml_cuda_threshold_for(op_id))
}

contract StubProbesYieldSizeMaxOnXeon {
    -- Concrete production-hardware contract: with the C8-C11
    -- `default_wins_stub` probes, every threshold on xeon's 2× RTX
    -- 6000 SKU calibrates to SIZE_MAX. test-calibration-ops-
    -- registered.cpp binds this on the actual host.
    forall op_id: OpId where op_id in {REDUCE_CROSS_DEVICE,
                                       MATMUL_STREAM_SPLIT,
                                       PEER_COPY,
                                       GRAPH_CAPTURE}:
        on_host("xeon"):
            ggml_cuda_threshold_for(op_id) == SIZE_MAX
}

-- ============================================================
-- Composition
-- ============================================================

-- Composes with:
--   calibrated_dispatch_framework.allium (C0)
--     - DispatchIsPureFunction
--     - CalibrationCompletesBeforeFirstDispatch
--     - ProbeIsDeterministic
--   libmgpu_subgraph_capture.allium (C7)
--     - LibmgpuCachedReplayMatchesPhase46Closure
--
-- The composition principle: calibrated ops are SAFE to deploy
-- because (a) calibration is deterministic, (b) the dispatch decision
-- is a pure function of (op, payload, threshold), and (c) the two
-- strategies produce equivalent outputs at the calibrated payload
-- size. Property (c) is vacuous on xeon with stub probes; it becomes
-- load-bearing when real probes ship.
