-- Implementation notes
-- ============================================================

-- Code-side anchors (paths from yarn-agentic root):
--   ik_llama.cpp/src/llama-context.h:37-100 (struct
--     llama_kv_cache; foundation slice n_stream + v_heads
--     already at ~lines 53-63 from submodule commit
--     969d156e).
--   ik_llama.cpp/src/llama.cpp:790-1155 (llama_kv_cache_init;
--     N1 reshapes K/V allocation to ggml_new_tensor_4d here).
--   ik_llama.cpp/src/llama.cpp:1156-1254 (llama_kv_cache_find_slot;
--     N1 rewrites this to per-stream scoping).
--   ik_llama.cpp/src/llama.cpp:1942-2204 (llama_kv_cache_clear,
--     _seq_rm, _seq_cp, _seq_keep, _seq_add, _seq_pos_min/max,
--     _defrag; N1 rewrites these per-stream).
--   ik_llama.cpp/src/llama-build-context.cpp (graph builders;
--     N2 threads per-stream strides through ~30-40 view/cpy
--     sites on kv_self.k_l[il] / kv_self.v_l[il]).
--   ik_llama.cpp/examples/server/server-context.cpp around line
--     4602 (the llama_decode call site; N2 splits the batch
--     per-stream and calls llama_decode once per active
--     stream under Option A).
--
-- Black-box helpers used inline in the invariants above (not in
-- `deferred` per project convention — they have no separate
-- .allium spec):
--   KVCells, Streams, DispatchUnits, DraftRegions, KVCacheSize,
--   NStream, TokensOf, MaskForUnit, CellsVisibleViaMask,
--   WriteRegionOf, CellsOfDispatchInRegion.
--
-- Test infrastructure to drive from this spec via allium:propagate
-- (planned as S4 in /home/llm/.claude/plans/cached-crunching-tiger.md):
--   - Property test that exercises find_slot for distinct
--     seq_ids and asserts allocated cells fall within the
--     expected per-stream range. EXPECTED TO FAIL on current
--     HEAD (legacy shared-pool find_slot); becomes PASS when
--     N1 lands.
--   - Stream-isolation property test (mirrors
--     scripts/r5-probe-c4.sh's behavioural intent but at the
--     cache layer): writes to stream s do not mutate stream
--     s' /= s. Already conceptually covered by
--     test-dflash-np-multislot; the propagated version is
--     unit-scale and runs against the cache directly.

-- ============================================================
-- Related specs
-- ============================================================

-- specs/scheduler/batch_composition.allium
--   The companion spec at the scheduler layer. Describes the
--   gates that close Bug C today; this spec describes the
--   layout that makes those gates redundant. Cross-references
--   MixedBatchProhibition, DecodeHoldGate,
--   PrefillSerialisationGate.
--
-- specs/dflash/dflash.allium
--   The DFlash drafter behavioural contract. Its
--   NoCrossSlotRegionOverlap and PerSlotDraftKVCache
--   invariants are upheld by this layout (per
--   DFlashCompatibility above).
--
-- specs/multislot/Decode.tla, specs/multislot/Fix.tla
--   The TLA+ model of the scheduler/dispatch state machine.
--   S2.b in the plan file (specs/multislot/StreamIsolation.tla)
--   ports this spec's invariants into TLC for exhaustive
--   model checking.
--
-- qnext_multislot_dispatch.allium
--   The engine-level per-block linear-attention dispatch
--   contract. Composes with PerStreamDispatch: when a
--   DispatchUnit reaches the engine, the qnext analyser sees
--   a single-seq batch (DispatchUnitTokensShareSeqId) and the
--   SINGLE-pattern fast path applies; the CONTIGUOUS_BLOCKS
--   path is no longer exercised in production.

-- ============================================================
-- Structural composition (closes entity-reference graph)
-- ============================================================
-- Top-level entity that holds every otherwise-unreferenced entity
-- as a List field so `allium check` sees the references bound.
-- Not a runtime object — purely structural.

entity NStreamLayerSystem {
    kv_tensors: List<KVTensor>
    kv_cells: List<KVCell>
    streams: List<Stream>
    slot_infos: List<SlotInfo>
    kq_masks: List<KQMask>
}

contract ValidateNStreamLayerSystem {
    invoke: (sys: NStreamLayerSystem) -> Boolean

    @invariant SystemReferencesBindAllEntities
        -- Structural composition: each List field above anchors an
        -- entity otherwise referenced only in invariant prose, so the
        -- spec's reference graph is closed under `allium check`.
}
