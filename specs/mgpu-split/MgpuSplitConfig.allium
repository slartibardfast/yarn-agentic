// MgpuSplitConfig.allium
//
// MgpuSplitConfig — Allium specification for the shared multi-GPU
// split-config data structure that Phase 46 Path B extracts from
// llama_model into a header-portable struct (src/ggml-mgpu-split.h).
//
// This is the data-structure spine of B.0-full: the other four B.0
// specs (BuftSetupLoop.tla, CreateSplitBalance.tla,
// ClipCrossDeviceFlow.tla, CrossCodepathConsistency.allium) all lean
// on the invariants asserted here.
//
// Scope: the struct's static invariants. Dynamics (the buft-setup
// loop populating it, the create_split algorithm operating against
// it) are modeled separately in the .tla specs that compose with
// this one — see the Composition section.
//
// Provenance: extracted from llama_model fields
//   model.splits        (std::vector<float>)         src/llama-model.h:?
//   model.split_buft    (ggml_backend_buffer_type_t) src/llama-model.h:496
//   model.devices       (std::vector<...>)           src/llama-model.h:?
//   model.buft_layer[]  (per-layer pair)             src/llama-model.h:?
//   model.default_layer_device[]                     src/llama-model.h:?
//   model.max_gpu, model.main_gpu                    src/llama-model.h:?
// plus the implicit per-device mem_used and capacity[] tracked
// inside create_split's loop body in llama-load-tensors.cpp:351.

entity MgpuSplitConfig {
    description: "Phase 46 Path B shared multi-GPU split config — extracted from llama_model, consumed by both LM and CLIP"

    fields {
        // Participating devices. Must be non-empty. For Phase 46
        // the production case is n_device = 2 (CUDA0, CUDA1).
        n_device:               int
        devices:                list[cuda_device]      // length = n_device

        // Per-device capacity bound in bytes. Set at config init
        // time by querying cudaMemGetInfo or by accepting a
        // user-supplied --tensor-split ratio applied to a global
        // budget. capacity[d] is the upper bound on what create_split
        // is permitted to allocate on device d.
        capacity:               list[bytes]            // length = n_device

        // Per-device cumulative allocation. Initialized to 0;
        // monotonically grows as create_split places weight rows.
        // Updated by both the LM-side and CLIP-side consumers.
        mem_used:               list[bytes]            // length = n_device

        // Normalized split ratio. splits[i] is the cumulative
        // fraction of the total weight pool allocated to devices
        // [0..i] inclusive. splits[n_device - 1] must equal 1.0
        // (every weight ends up on some device). Source: parsed
        // from --tensor-split / MTMD_TENSOR_SPLIT CLI/env input.
        splits:                 list[float]            // length = n_device, in [0, 1]

        // The shared CUDA split buffer type — constructed via
        // llama_default_buffer_type_split() →
        // ggml_backend_cuda_split_buffer_type(splits.data()).
        // Non-null iff n_device > 1 AND split_mode ∈ {ATTN, GRAPH}.
        // Null under NONE / LAYER / single-device configurations.
        split_buft:             buffer_type            // nullable

        // The split mode this config was constructed for. Frozen
        // at config-init time; never mutated after.
        split_mode:             enum { NONE, LAYER, ATTN, GRAPH }

        // Layer enumeration. n_layer is the total transformer-layer
        // count; for the LM this is hparams.n_layer; for CLIP this
        // is the ViT depth. i_gpu_start is the index of the first
        // layer assigned to GPU(s) — layers [0, i_gpu_start) live
        // on CPU (the LM's offload-fewer-than-all-layers case).
        n_layer:                int
        i_gpu_start:            int                    // 0 ≤ i_gpu_start ≤ n_layer

        // Per-layer buffer-type pair. buft_layer[i].split is the
        // shared split_buft (or null for non-graph modes);
        // buft_layer[i].offload is a single-device buft chosen for
        // this layer's non-row-split tensors (norms, bias, etc.).
        // Asymmetric: split component may be null even when offload
        // is set (NONE / LAYER cases).
        buft_layer:             list[{split: buffer_type, offload: buffer_type}]  // length = n_layer

        // Per-layer default device. For LAYER mode this is the
        // exclusive owner; for GRAPH/ATTN modes it's the
        // "preferred" device used for non-split tensors and as
        // the per-layer offload-buft selector. -1 sentinel for
        // CPU-only layers.
        default_layer_device:   list[int]              // length = n_layer, in {-1, 0..n_device-1}

        // Tensor → device residency, populated AFTER create_split
        // completes. For LAYER mode every tensor maps to exactly
        // one device. For GRAPH/ATTN modes a tensor's rows may
        // span devices; in this model we represent it as a
        // residency over the tensor's row-chunk set, with
        // tensor_residency[t][r] = device-id of row r.
        tensor_residency:       map[tensor → map[row → int]]

        // The set of weight tensors this config places. Populated
        // before create_split runs; not mutated after.
        weight_tensors:         set[tensor]

        // Per-tensor row count, frozen at load time.
        n_rows:                 map[tensor → int]
    }

    // ========================================================
    // INVARIANTS — must hold for any valid MgpuSplitConfig state
    // ========================================================
    invariants {

        // === Cardinality ===

        @DevicesNonEmpty
            "at least one device is configured"
            // n_device ≥ 1. CPU-only configs use a single CPU
            // entry; multi-GPU configs use multiple CUDA entries.
            // Phase 46's production target is n_device = 2.

        @ListLengthsMatchNDevice
            "devices, capacity, mem_used, splits all length n_device"
            // devices.size() = capacity.size() = mem_used.size()
            //                = splits.size() = n_device.

        @LayerListLengthsMatchNLayer
            "buft_layer and default_layer_device length n_layer"
            // buft_layer.size() = default_layer_device.size() = n_layer.

        // === Split ratio shape ===

        @SplitsMonotonic
            "cumulative split fractions are non-decreasing"
            // For all i ∈ [0, n_device - 1): splits[i] ≤ splits[i + 1].

        @SplitsNormalized
            "splits is a CDF: ends at 1.0, all values in [0, 1]"
            // splits[n_device - 1] = 1.0.
            // For all i: 0 ≤ splits[i] ≤ 1.0.
            // splits[0] may be 0 (a zero-share device is permitted —
            // the upstream parser tolerates this — though Phase 46's
            // production case always has splits[0] > 0).

        // === Buft assignment ===

        @SplitBuftPresentIffGraphLikeAndMultiDevice
            "split_buft non-null exactly when (n_device > 1 and
             split_mode ∈ {ATTN, GRAPH})"
            // split_buft = null iff
            //   n_device = 1 OR split_mode ∈ {NONE, LAYER}.
            // This invariant binds on the ground truth read out
            // of llama.cpp:4170-4173 during ground-truth analysis.

        @NoOrphanGpuLayers
            "every GPU-assigned layer has buft_layer fully populated"
            // For all i ∈ [i_gpu_start, n_layer):
            //   buft_layer[i].offload is non-null
            //   AND (split_buft is null OR buft_layer[i].split = split_buft).
            // CPU layers (i < i_gpu_start) have buft_layer[i].offload
            // = the default CPU buft and buft_layer[i].split = null.

        @LayerDeviceInRange
            "default_layer_device[i] either -1 (CPU) or a valid GPU index"
            // For all i: default_layer_device[i] ∈ {-1} ∪ [0, n_device).
            // For i < i_gpu_start: default_layer_device[i] = -1.
            // For i ≥ i_gpu_start: default_layer_device[i] ∈ [0, n_device).

        // === Memory bookkeeping ===

        @MemUsedNonNegative
            "no device has negative usage"
            // For all d: mem_used[d] ≥ 0.

        @CapacityHonored
            "no device exceeds its capacity at any reachable state"
            // For all d: mem_used[d] ≤ capacity[d].
            // This is the binding fit invariant for Phase 46 — if
            // it's violated, the LM/CLIP allocation will fail with
            // cudaErrorMemoryAllocation. CreateSplitBalance.tla
            // models the dynamic walk that establishes this; the
            // present spec only asserts the static post-condition.

        // === Residency consistency ===

        @ResidencyTotal
            "every weight tensor row has a residency mapping"
            // For all t ∈ weight_tensors: for all r ∈ [0, n_rows[t]):
            //   tensor_residency[t][r] is defined.

        @ResidencyInDeviceRange
            "every residency entry points to a real device"
            // For all t, r: tensor_residency[t][r] ∈ [0, n_device).

        @ResidencyConsistentWithBuft
            "a tensor's residency matches its buft"
            // Under LAYER mode (split_buft = null): every row of
            // tensor t is on the same device, and that device is
            // the one corresponding to the offload buft assigned
            // to t's layer.
            // Under GRAPH/ATTN modes (split_buft non-null): a
            // tensor's rows may span devices; the row ranges
            // assigned to each device must agree with the create_split
            // post-condition (modeled separately in
            // CreateSplitBalance.tla).

        @NoMultiResidency
            "a single row lives on exactly one device, never both"
            // For all t, r: |{d : tensor_residency[t][r] = d}| = 1.
            // This rules out the row-double-residency bug class
            // that the K/V family orphan-audit flagged as a risk
            // surface elsewhere in the codebase.

        // === Frozen-after-init guarantees ===

        @SplitModeImmutable
            "split_mode does not change after config init"
            // No state transition modifies split_mode. Set once
            // at construction time from --split-mode (LM) or
            // --mmproj-split-mode (CLIP). Codepath consistency
            // (CrossCodepathConsistency.allium) leans on this.

        @SplitsImmutable
            "the splits ratio does not change after config init"
            // No state transition modifies splits[]. Set once
            // from --tensor-split / --mmproj-tensor-split.

        @CapacityImmutable
            "capacity does not change after config init"
            // mem_used grows; capacity is frozen. This rules
            // out the "shrinking budget mid-run" failure mode.

        // === Path B-specific: the LM/CLIP shared-struct guarantee ===

        @ConsumerAgnostic
            "every invariant above holds independently of who
             instantiated this config (LM or CLIP)"
            // The struct's invariants do not reference any
            // llama_model or clip_ctx field. This is what makes
            // the Path B extraction safe: both consumers see
            // identical structural guarantees. Cross-codepath
            // consistency is asserted separately in
            // CrossCodepathConsistency.allium.
    }

    // ========================================================
    // COMPOSITION — how the other B.0 specs lean on this one
    // ========================================================
    //
    // BuftSetupLoop.tla models the loop at llama.cpp:4168-4198
    // that populates a fresh MgpuSplitConfig. Its post-condition
    // asserts every invariant in this spec holds at loop exit.
    //
    // CreateSplitBalance.tla models the create_split() function
    // at llama-load-tensors.cpp:351 operating against an
    // already-populated MgpuSplitConfig. Its action invariants
    // assert that mem_used is updated correctly and that
    // @CapacityHonored stays satisfied across every step.
    //
    // ClipCrossDeviceFlow.tla models per-layer CLIP compute and
    // transfer against a MgpuSplitConfig with n_device = 2 and
    // split_mode = GRAPH. It treats this spec's invariants as
    // axioms — does not re-prove them.
    //
    // CrossCodepathConsistency.allium asserts that any state
    // legal here is legal under both LM and CLIP consumption.
    // It refines @ConsumerAgnostic into per-consumer state
    // predicates and proves their equivalence.

    // ========================================================
    // OUT OF SCOPE
    // ========================================================
    //
    // - The dynamic walk that creates the residency mapping
    //   (modeled in CreateSplitBalance.tla).
    // - The buft-setup loop semantics (modeled in BuftSetupLoop.tla).
    // - Cross-device compute/transfer scheduling
    //   (modeled in ClipCrossDeviceFlow.tla, extending AsyncReduce.tla).
    // - Quantization-type interactions with split_buft alignment
    //   (handled by ggml_backend_cuda_split_buffer_type's
    //   internal alignment math; not exposed at the config level).
    // - The MTP nextn-layer per-device override path
    //   (llama-load-tensors.cpp:313-318). Phase 46 does not
    //   touch MTP; that path stays LM-only and its model state
    //   is not represented in this struct.
    //
    // Acceptance for this spec at B.0.1:
    //   Alloy Analyzer finds no counterexample at scope ≥ 8
    //   over n_device, n_layer, weight_tensors. The check
    //   exercises all sixteen invariants above against every
    //   reachable state in the bounded model.
}
