-- allium: 3
-- specs/mgpu-split/CrossCodepathConsistency.allium
--
-- Scope: the cross-consumer equivalence properties layered on top of
-- MgpuSplitConfig.allium (spec #1), BuftSetupLoop.tla (spec #2), and
-- CreateSplitBalance.tla (spec #3). The structural binding contract
-- of Phase 46 Path B is: one implementation, two consumers. This
-- spec proves that for any state legal under the LM-side consumer,
-- the same state is legal under the CLIP-side consumer, and vice
-- versa.
--
-- Why this spec exists:
--   The risk of any extract-and-share refactor is that the two
--   consumers diverge subtly over time: a "convenience" field added
--   to one consumer's view, a default value set differently, a
--   sequence of mutations valid on one side but pathological on the
--   other. The orphan audit at PHASE46 §12.5 flagged
--   create_tensors_helper + buft-setup loop as the LM-side touch
--   surface (LOW-MEDIUM risk, ~50 read sites). This spec asserts
--   the binding contract that mitigates that risk: the struct's
--   invariants and dynamics are consumer-agnostic.
--
-- Composition:
--   - Takes MgpuSplitConfig.allium's sixteen invariants as axioms.
--   - Takes BuftSetupLoop.tla's NoOrphanGpuLayersAtExit,
--     SplitBuftPresentAtExitIffRequired,
--     PerLayerDeviceMatchesUpperBound as axioms.
--   - Takes CreateSplitBalance.tla's SumInvariantAtExit, NonNegative,
--     NoMultiResidency, CapacityHonored as axioms.
--   - Refines MgpuSplitConfig.allium's ConsumerAgnostic into the
--     per-consumer state predicates below.
--
-- Acceptance for B.0:
--   `allium check` passes (no errors).
--   The runtime obligation ledger binds each invariant below to a
--   C++ test in tests/test-mgpu-split-cross-codepath.cpp.

-- ============================================================
-- External entities
-- ============================================================

-- Which consumer codepath is exercising the shared struct.
enum Consumer {
    lm | clip
}

-- A reference to MgpuSplitConfig from spec #1, paired with the
-- consumer that holds the view. The struct itself is shared (same
-- backing memory); only the access path differs.
entity ConfigInstance {
    consumer: Consumer
    access_paths: List<String>      -- names of call sites that touch the struct
}

-- A pair of (LM, CLIP) ConfigInstances over the same backing
-- MgpuSplitConfig. The whole point of Path B is that this pair
-- exists at runtime: one struct, two views.
entity CrossCodepathPair {
    lm_view: ConfigInstance         -- consumer = lm
    clip_view: ConfigInstance       -- consumer = clip
}

-- ============================================================
-- Per-ConfigInstance invariants
-- ============================================================

invariant ConfigInstanceWellFormed {
    -- Every ConfigInstance references a valid MgpuSplitConfig (spec
    -- #1's sixteen invariants hold). Asserted axiomatically — the
    -- struct's static invariants are spec #1's responsibility.
}

invariant AccessPathsBelongToConsumer {
    -- LM ConfigInstances access only LM-side call sites; CLIP
    -- ConfigInstances access only CLIP-side call sites. No call site
    -- appears in both sets — the two consumers are syntactically
    -- separate codepaths.
    --
    -- LM access paths (set):
    --   create_tensors_helper_ctor
    --   create_tensors_helper_ctx_for_layer_split
    --   per_arch_create_llama_tensors  (and analogues per architecture)
    --   llama_cpp_4168_buft_setup_loop
    --   llama_load_tensors_create_split_call_sites_x13
    --
    -- CLIP access paths (set):
    --   clip_cpp_488_init
    --   clip_cpp_weight_loader
    --   clip_cpp_create_split_call
    --
    -- The sets are disjoint.
}

-- ============================================================
-- CrossCodepathPair bidirectional equivalence invariants
-- ============================================================
-- These are the load-bearing assertions of this spec.

invariant PairOverSameStruct {
    -- For every CrossCodepathPair: lm_view and clip_view point to
    -- the SAME backing MgpuSplitConfig. The struct lives in a single
    -- allocation; both consumers hold pointers to it.
}

invariant PairConsumersDistinct {
    -- For every CrossCodepathPair:
    --   lm_view.consumer = lm AND clip_view.consumer = clip.
    -- Asserts that the pair covers both consumer types and does not
    -- conflate them.
}

invariant InvariantSatisfactionEquivalent {
    -- For every MgpuSplitConfig invariant I (the sixteen from spec
    -- #1): I evaluated through lm_view holds IFF I evaluated through
    -- clip_view holds.
    --
    -- This is structurally trivial — the invariants are stated on
    -- the shared struct, which both views point to. But it's the
    -- explicit form that the Alloy Analyzer counterexample search
    -- exercises. A bug where one consumer "sees a different value"
    -- through some convenience accessor would produce a
    -- counterexample here.
}

invariant BuftSetupOutputEquivalent {
    -- Refinement: the post-condition of BuftSetupLoop.tla
    -- (NoOrphanGpuLayersAtExit, SplitBuftPresentAtExitIffRequired,
    -- PerLayerDeviceMatchesUpperBound) is observable identically
    -- through both lm_view and clip_view.
    --
    -- Operationally: if the LM ran BuftSetupLoop and produced
    -- buft_layer[i] = {split, offload(0)} for all GPU layers, then
    -- CLIP — viewing the SAME struct — also sees that exact
    -- assignment.
}

invariant CreateSplitOutputEquivalent {
    -- Refinement: the post-condition of CreateSplitBalance.tla
    -- (SumInvariantAtExit, NonNegative, BoundedAtExit) is observable
    -- identically through both lm_view and clip_view under the same
    -- inputs.
    --
    -- Together with BuftSetupOutputEquivalent, this discharges
    -- Path B's claim that one implementation suffices for two
    -- consumers.
}

invariant MutationsByOneConsumerVisibleToOther {
    -- If LM mutates the struct (e.g. increments mem_used[d] when it
    -- allocates LM weights), CLIP — viewing the SAME struct — sees
    -- the same mutation.
    --
    -- This invariant matters for B.5 because CLIP's create_split
    -- call must see the LM-side mem_used[d] that accumulated during
    -- LM weight loading. CLIP loads mmproj AFTER the LM is up; the
    -- LM's allocations are already accounted for and must inform
    -- CLIP's balance.
}

invariant ImmutableFieldsBidirectionallyImmutable {
    -- Fields marked SplitModeImmutable, SplitsImmutable,
    -- CapacityImmutable in spec #1 are immutable from BOTH consumer
    -- codepaths. No LM-side code path mutates split_mode, splits, or
    -- capacity after init; likewise no CLIP-side code path.
    --
    -- This is what permits both consumers to safely cache local
    -- copies of those values (e.g. for the inner matmul loops).
}

-- ============================================================
-- Path B refactor-preservation contract
-- ============================================================

invariant LmRefactorPreservesAllLmInvariants {
    -- After B.3-B.4 refactor of create_tensors_helper and
    -- llama.cpp:4168-4198, every LM-side invariant that held before
    -- B.3-B.4 still holds.
    --
    -- The refactor moves field reads from inline access on
    -- model.splits / model.split_buft / model.devices to access
    -- through an mgpu_split_config&. Field VALUES are unchanged;
    -- only the access expression changes.
    --
    -- This is what permits B.6's LM gate re-cert (G3.a, G3.c,
    -- test-n-stream-kv-layout, Phase 45 D10.a) to succeed without
    -- any test-level changes. The invariant is load-bearing on B.6.
}

invariant ClipIntroductionPreservesAllLmInvariants {
    -- Adding a second consumer (CLIP) to a shared struct does not
    -- in itself change any LM-observable behavior.
    --
    -- Caveat: CLIP DOES increment mem_used[d] when it allocates
    -- mmproj weights. This is intentional and is the SAME mechanism
    -- the LM uses; it does not break any invariant because mem_used
    -- is the one mutable field. CapacityHonored holds under
    -- arbitrary mutation order because the loop construction in
    -- CreateSplitBalance.tla establishes the bound at the time of
    -- allocation.
}

-- ============================================================
-- End-user observational equivalence
-- ============================================================

invariant LmObservableBehaviorUnchanged {
    -- An external observer (e.g. G3.a determinism test) cannot
    -- distinguish pre-B.0 from post-B.8 LM behavior under the same
    -- inputs.
    --
    -- This is the binding contract for the user-visible claim that
    -- Path B is "semantics-preserving on the LM side." If this
    -- invariant is violated by any refactor step, the phase stays
    -- OPEN.
    --
    -- Verified by:
    --   - This spec (formal, via Alloy Analyzer).
    --   - B.6 LM gate re-cert (empirical, post-code).
}

invariant ClipNewObservableBehaviorIsAdditive {
    -- The new CLIP behaviors are strictly additive: an external
    -- observer of the LM cannot tell whether CLIP is in single-GPU
    -- or multi-GPU mode.
    --
    -- The LM's matmul outputs, KV-cache evolution, and
    -- token-emission distribution are unchanged by CLIP's mode
    -- change. CLIP's mode change is observable only through:
    --   (a) per-device VRAM usage (mmproj rows on both devices
    --       instead of just one);
    --   (b) CLIP encode latency (<= 1.3x single-GPU per P7);
    --   (c) the journal log lines from Step 1 / B.5.
    -- No third channel observable to the LM exists.
}

-- ============================================================
-- Contracts — bind the entity formally for the spec checker
-- ============================================================

contract CheckPair {
    invoke: (pair: CrossCodepathPair) -> Boolean

    @invariant PairSatisfiesAllConsistencyInvariants
        -- Returns true iff `pair` satisfies every invariant above.
        -- Run conceptually at every LM / CLIP refactor checkpoint
        -- to confirm the two consumers remain over the same
        -- MgpuSplitConfig with the expected codepath separation.
}
