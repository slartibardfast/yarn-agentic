// CrossCodepathConsistency.allium
//
// CrossCodepathConsistency — Allium specification asserting that the
// shared mgpu_split_config struct introduced by Phase 46 Path B
// behaves identically under both consumers (llama_model AND
// clip_ctx). The structural binding contract of Path B is: one
// implementation, two consumers. This spec proves that.
//
// Phase 46 §12.2 spec #5 — last of the five B.0-full specs.
//
// Scope: refinement and cross-consumer equivalence properties layered
// on top of MgpuSplitConfig.allium (spec #1), BuftSetupLoop.tla
// (spec #2), and CreateSplitBalance.tla (spec #3). This spec does not
// re-prove those specs' invariants — it consumes them as axioms and
// adds the bidirectional consumer-equivalence properties.
//
// Why this spec exists:
//   The risk of any extract-and-share refactor is that the two
//   consumers diverge subtly over time: a "convenience" field added
//   to one consumer's view, a default value set differently, a
//   sequence of mutations that's valid on one side but pathological
//   on the other. The orphan audit at PHASE46 §12.5 flagged
//   create_tensors_helper + buft-setup loop as the LM-side touch
//   surface (LOW-MEDIUM risk, ~50 read sites). This spec asserts
//   the binding contract that mitigates that risk: the struct's
//   invariants and dynamics are consumer-agnostic.

entity ConfigInstance {
    description: "An mgpu_split_config struct as observed by a specific consumer (LM or CLIP)"

    fields {
        // Reference to the underlying struct (axiomatic — defined
        // in MgpuSplitConfig.allium).
        config:        MgpuSplitConfig

        // Which consumer holds this view.
        consumer:      enum { LM, CLIP }

        // Which call sites the consumer reaches into the struct
        // through. For the LM, this is create_tensors_helper +
        // buft-setup loop. For CLIP, this is the new clip.cpp
        // wiring under Path B B.5.
        access_paths:  set[call_site]
    }

    invariants {

        @ConfigInstanceWellFormed
            "every ConfigInstance references a valid MgpuSplitConfig"
            // config satisfies all sixteen invariants of
            // MgpuSplitConfig.allium. Asserted as an axiom — the
            // struct's static invariants are spec #1's responsibility.

        @AccessPathsBelongToConsumer
            "LM ConfigInstances access only LM call sites, and same
             for CLIP"
            // For LM: access_paths ⊆ {create_tensors_helper,
            //         buft_setup_loop_at_llama_cpp_4168,
            //         per_layer_tensor_loaders, ...}
            // For CLIP: access_paths ⊆ {clip_init_at_488,
            //          clip_weight_loader, ...}
            // No call site appears in BOTH sets — the two consumers
            // are syntactically separate codepaths.
    }
}

entity CrossCodepathPair {
    description: "A pair of (LM, CLIP) ConfigInstances over the same underlying MgpuSplitConfig"

    fields {
        lm_view:    ConfigInstance         // .consumer = LM
        clip_view:  ConfigInstance         // .consumer = CLIP
        // Both view the SAME underlying struct.
        shared:     MgpuSplitConfig
    }

    invariants {

        @PairOverSameStruct
            "both views point to the same struct"
            // lm_view.config = clip_view.config = shared.

        @PairConsumersDistinct
            "the pair covers both consumer types"
            // lm_view.consumer = LM AND clip_view.consumer = CLIP.

        // ================================================
        // BIDIRECTIONAL CONSUMER-EQUIVALENCE PROPERTIES
        //
        // These are the load-bearing assertions of this spec.
        // ================================================

        @InvariantSatisfactionEquivalent
            "every MgpuSplitConfig invariant holds under LM view iff
             it holds under CLIP view"
            // For every invariant I in MgpuSplitConfig:
            //   I(shared) interpreted via lm_view ⇔
            //   I(shared) interpreted via clip_view
            //
            // This is structurally trivial (the invariants are on
            // shared, which both views point to) — but it's the
            // explicit form that the Alloy Analyzer counterexample
            // search exercises. A bug where one consumer "sees a
            // different value" through some convenience accessor
            // would produce a counterexample here.

        @BuftSetupOutputEquivalent
            "the post-state of BuftSetupLoop is observable identically
             through both views"
            // Refinement: BuftSetupLoop.tla establishes a post-condition
            // on shared (NoOrphanGpuLayersAtExit,
            // SplitBuftPresentAtExitIffRequired, etc.). This invariant
            // says that post-condition is observable to BOTH consumers,
            // not just the one that ran the loop.
            //
            // Operationally: if the LM ran BuftSetupLoop and produced
            // buft_layer[i] = {SPLIT, OFFLOAD(0)} for all GPU layers,
            // then CLIP — viewing the SAME struct — also sees
            // buft_layer[i] = {SPLIT, OFFLOAD(0)} for all GPU layers.

        @CreateSplitOutputEquivalent
            "create_split's post-state is observable identically
             through both views"
            // Refinement: CreateSplitBalance.tla establishes
            // SumInvariantAtExit, NonNegative, etc. This invariant
            // says those post-conditions are observable to BOTH
            // consumers under the SAME inputs.
            //
            // Together with @BuftSetupOutputEquivalent, this
            // discharges Path B's claim that one implementation
            // suffices for two consumers.

        @MutationsByOneConsumerVisibleToOther
            "if LM mutates the struct (e.g. increments mem_used[d]),
             CLIP sees the same mutation"
            // The struct lives in a single allocation; both consumers
            // hold pointers to it. There is no per-consumer caching
            // layer between the consumers and the struct.
            //
            // This invariant matters for B.5 because CLIP's
            // create_split call must see the LM-side mem_used[d]
            // that accumulated during LM weight loading (CLIP loads
            // mmproj AFTER the LM is up — the LM's allocations are
            // already accounted for).

        @ImmutableFieldsBidirectionallyImmutable
            "fields marked @SplitModeImmutable, @SplitsImmutable,
             @CapacityImmutable in spec #1 are immutable from BOTH
             consumer codepaths"
            // No LM-side code path mutates split_mode, splits, or
            // capacity after init. Likewise no CLIP-side code path.
            // This is what permits both consumers to safely cache
            // local copies of those values (e.g. for the inner
            // matmul loops).

        // ================================================
        // PATH B REFACTOR-PRESERVATION CONTRACT
        // ================================================

        @LmRefactorPreservesAllLmInvariants
            "after B.3-B.4 refactor of create_tensors_helper and
             llama.cpp:4168-4198, every LM-side invariant that held
             before B.3-B.4 still holds"
            // The refactor moves field reads from inline access on
            // model.splits / model.split_buft / model.devices to
            // access through an mgpu_split_config &. Field VALUES
            // are unchanged; only the access expression changes.
            //
            // This is what permits B.6's LM gate re-cert (G3.a, G3.c,
            // test-n-stream-kv-layout, Phase 45 D10.a) to succeed
            // without any test-level changes. The invariant is
            // load-bearing on B.6.

        @ClipIntroductionPreservesAllLmInvariants
            "the new CLIP consumer (B.5) does not perturb any
             LM-side invariant"
            // Adding a second consumer (CLIP) to a shared struct
            // does not in itself change any LM-observable behavior.
            //
            // Caveat: CLIP DOES increment mem_used[d] when it
            // allocates mmproj weights. This is intentional and
            // is the SAME mechanism the LM uses; it does not break
            // any invariant because mem_used is the one mutable
            // field. @CapacityHonored holds under arbitrary
            // mutation order because the loop construction in
            // CreateSplitBalance.tla establishes the bound at the
            // time of allocation.

        // ================================================
        // OBSERVATIONAL EQUIVALENCE OF END-USER EFFECT
        // ================================================

        @LmObservableBehaviorUnchanged
            "an external observer (e.g. G3.a determinism test)
             cannot distinguish pre-B.0 from post-B.8 LM behavior
             under the same inputs"
            // This is the binding contract for the user-visible
            // claim that Path B is "semantics-preserving on the
            // LM side." If this invariant is violated by any
            // refactor step, the phase stays OPEN.
            //
            // Verified by:
            //   - This spec (formal).
            //   - B.6 LM gate re-cert (empirical, post-code).

        @ClipNewObservableBehaviorIsAdditive
            "the new CLIP behaviors are strictly additive: an external
             observer of the LM cannot tell whether CLIP is in
             single-GPU or multi-GPU mode"
            // The LM's matmul outputs, KV-cache evolution, and
            // token-emission distribution are unchanged by CLIP's
            // mode change. CLIP's mode change is observable only
            // through:
            //   (a) per-device VRAM usage (mmproj rows on both
            //       devices instead of just one);
            //   (b) CLIP encode latency (≤ 1.3× single-GPU per P7);
            //   (c) the journal log lines from Step 1 and B.5.
            // No third party observable to the LM exists.
    }

    // ========================================================
    // OUT OF SCOPE
    // ========================================================
    //
    // - The dynamics of mem_used updates over time within either
    //   consumer (modeled in CreateSplitBalance.tla, consumed as axiom).
    // - The MTP nextn-layer per-device override path (llama-load-tensors.cpp:313-318).
    //   Phase 46 does not touch MTP; this spec inherits that scope
    //   restriction from spec #1.
    // - Multi-thread safety. mgpu_split_config is constructed once
    //   at init time and only mem_used mutates after; all mutators
    //   run from the main thread serially. If multi-threaded
    //   consumers are introduced later, this spec needs a refinement.
    // - LM/CLIP teardown ordering. Phase 46 does not change teardown
    //   sequencing; the existing destruction order in llama_free()
    //   suffices.
    //
    // Acceptance for this spec at B.0.1:
    //   Alloy Analyzer finds no counterexample at scope ≥ 4 over
    //   {LM, CLIP} pairs. Even at small scope, the bidirectional
    //   nature of the assertions means any divergence (asymmetric
    //   field visibility, one-sided mutation effect, ...) produces
    //   a counterexample.
    //
    //   Combined with the four prior specs' bounds (≥ 8 for
    //   MgpuSplitConfig, ≥ 4 for TLA+ specs), B.0-full is closed
    //   when all five PASS in CI / a documented manual run.
}
