-- ============================================================
-- Related specs
-- ============================================================

-- specs/scheduler/batch_composition.allium
--   The scheduler-layer admission contract. Under Tier 4 this spec
--   was rewritten to express chunked-prefill admission
--   (TokenBudgetPerUbatch + DecodePriorityAdmission +
--   ChunkedPrefillAdmission + PrefillCarryProgressesMonotonically).
--   Bug C absence — formerly defended by that spec's
--   MixedBatchProhibition + DecodeHoldGate — is now delegated to
--   THIS spec's BugCAbsenceUnderUnifiedDispatch /
--   PreservesBugCAbsence (the structural kernel-input-shape
--   closure). Under Tier 4, mixed prefill+decode admission is
--   allowed and Bug C absence holds regardless.
--
-- specs/kv-cache/n_stream_layer.allium
--   The 4D per-stream KV layout. Tier 3 builds on this; ne[3] of
--   the K and V tensors = n_stream; the per-CTA bind under
--   unified dispatch reads exactly one stream's slab via the
--   ne[3] stride. StreamPartition and NoCrossStreamLeakage from
--   that spec are LIFTED TO THE KERNEL-INPUT LAYER under unified
--   dispatch (per PreservesBugCAbsence.
--   PerStreamReadIsolationLiftedToNe3Axis).
--
-- specs/kv-cache/per_stream_read_view_patching.allium
--   The Tier-2 read-view per-stream patching contract. Tier 3
--   SUBSUMES this: under unified dispatch the read views span
--   ne[3] = n_stream naturally and the per-call data-pointer patch
--   becomes redundant. The Tier-2 patching code may be removed at
--   Tier-3 close (or left as a no-op at n_active_streams = 1 for
--   compatibility with single-stream profiles); the contract
--   surface in that spec is STRICTLY WEAKER than this spec's
--   RaggedFAComposition + PreservesBugCAbsence.
--
-- specs/graphs/cuda_graph_reuse.allium
--   The CUDA backend's cache mechanism. Tier 3's stable per-tick
--   topology (one shape per active-stream count) is strictly
--   better for its TopologyHashLookup: the cache holds one entry
--   per (n_active_streams, per_stream_token_count, n_kv_bucket)
--   tuple, with all decode ticks at the same shape hitting the
--   same entry. StableTopologyAcrossDecodeTicks above formalises
--   this property.
--
-- specs/dflash/dflash.allium
--   The DFlash drafter behavioural contract. Tier 3 composes
--   cleanly: DFlash Phase 5's draft-side batched dispatch is
--   independent of the verify-side dispatch model (the
--   common_speculative_draft_batched call fans out to drafter
--   contexts, not to the target llama_decode). Tier 3 unifies
--   the verify-side dispatch only; the DFlash kernel-side
--   invariants (NoCrossSlotRegionOverlap,
--   PerSlotDraftKVCache) hold under both per-stream and unified
--   verify-side dispatch.

-- ============================================================
-- Structural composition (closes entity-reference graph)
-- ============================================================
-- Top-level entity that holds every otherwise-unreferenced entity
-- as a List field so `allium check` sees the references bound.
-- Not a runtime object — purely structural.

entity UnifiedStreamDispatchSystem {
    unified_batch_slices: List<UnifiedBatchSlice>
    op_invocations: List<OpInvocation>
}

contract ValidateUnifiedStreamDispatchSystem {
    invoke: (sys: UnifiedStreamDispatchSystem) -> Boolean

    @invariant SystemReferencesBindAllEntities
        -- Structural composition: each List field above anchors an
        -- entity otherwise referenced only in invariant prose, so the
        -- spec's reference graph is closed under `allium check`.
}
