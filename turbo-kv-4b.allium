-- allium: 3
-- turbo-kv-4b.allium

-- Scope: TURBO_KV_4B KV cache quantization
-- Includes: Block layout, quantize, dequantize, vec_dot, RHT transform
-- Excludes:
--   - SIMD implementations (AVX2, AVX512, SSE4.1, ARM) — implementation detail
--   - Vulkan shaders — implementation detail
--   - CUDA/ROCM backends — not yet implemented
--   - TURBO_2B/3B/4B/5B weight quantization — separate concern
--   - Custom codebook loading — extension point
--   - imatrix-weighted quantization — inactive path

-- ============================================================
-- External entities (managed by ggml/tensor system)
-- ============================================================

external entity Tensor {
    data: Set<Decimal>
    count: Integer
}

actor TensorSupplier {
    identified_by: Tensor
}

-- ============================================================
-- Value types
-- ============================================================

value BlockId {
    index: Integer
}

-- A quantized KV block: 128 float elements → 72 bytes
entity TurboBlock {
    norm: Decimal          -- L2 norm of original 128-elem vector
    inv_std: Decimal       -- CENT_MAX / max(|RHT(normalized)|)
    indices: Set<Integer>  -- 128 codebook indices, each in [0, 15]
}

-- ============================================================
-- Config
-- ============================================================

config {
    block_size: Integer = 128
    codebook_size: Integer = 16
    seed: Integer = 305419896  -- 0x12345678
    cent_max: Decimal = 2.7326
}

-- ============================================================
-- Rules
-- ============================================================

rule QuantizeBlock {
    when: QuantizeBlock(tensor, seed)

    requires: tensor.count = config.block_size

    let norm = L2_norm(tensor.data)
    let rotated = RHT_forward(normalize(tensor.data), config.seed)
    let max_val = max(rotated)
    let inv_std = config.cent_max / max_val
    let indices = nearest_centroid(tensor.data, inv_std)

    ensures: TurboBlock.created(
        norm: norm,
        inv_std: inv_std,
        indices: indices
    )
}

rule DequantizeBlock {
    when: DequantizeBlock(block)

    let codebook_values = reconstruct_codebook(block)
    let dequant_rotated = RHT_inverse(codebook_values, config.seed)
    let reconstructed = rescale(dequant_rotated, block.norm)

    ensures: Tensor.created(
        data: reconstructed,
        count: config.block_size
    )
}

rule VectorDot {
    when: VectorDot(query, block)

    requires: query.count = config.block_size

    let q_rotated = RHT_forward(query.data, config.seed)
    let k_dequant = reconstruct_codebook(block)
    let dot_result = dot_product(q_rotated, k_dequant) * block.norm

    ensures: result = dot_result
}

-- ============================================================
-- Invariants
-- ============================================================

invariant ReconstructionPreservesNorm {
    for block in TurboBlocks:
        for original in QuantizedVectors:
            let reconstructed = dequantize(block)
            abs(L2_norm(reconstructed) - L2_norm(original)) <= quantization_error_bound
}

invariant RHTOrthogonality {
    for a in Vectors:
        for b in Vectors:
            for seed in Seeds:
                let a_rot = RHT_forward(a, seed)
                let b_rot = RHT_forward(b, seed)
                dot_product(a_rot, b_rot) = dot_product(a, b)
}

invariant DeterministicSeed {
    config.seed = 305419896
}

invariant BlockSizeFixed {
    config.block_size = 128
}

invariant IndicesInBounds {
    for block in TurboBlocks:
        for idx in block.indices:
            idx >= 0 and idx < config.codebook_size
}

-- ============================================================
-- Deferred specifications (algorithm-level: resolved in separate files)
-- ============================================================

-- RESOLVED — each has its own distilled spec:
-- RHT_forward    -> turbo-rht.allium rule RHT_forward
-- RHT_inverse    -> turbo-rht.allium rule RHT_inverse
-- L2_norm        -> turbo-l2norm.allium rule L2_norm
-- normalize      -> turbo-normalize.allium rule normalize
-- nearest_centroid -> turbo-nearest-centroid.allium rule nearest_centroid
-- reconstruct_codebook -> turbo-reconstruct.allium rule reconstruct_codebook
-- rescale        -> turbo-rescale.allium rule rescale

-- REMAINING deferred (black-box helpers, never formally specified):
deferred dot_product    -- black box: sum of element-wise products
deferred max            -- black box: maximum of collection
deferred abs            -- black box: absolute value
deferred ceil           -- black box: ceiling division
deferred zero_pad       -- black box: append zero elements

-- ============================================================
-- Deferred implementations
-- ============================================================

-- The following SIMD/backend implementations are NOT yet provided.
-- They must produce results identical to the scalar reference path.
-- PPL quality on the target model must match the CPU baseline.

deferred AVX2_Quantize    -- see: ggml-cpu/arch/x86/turbo_kv_4b_sse.h (AVX2 port)
deferred AVX512_Quantize  -- see: ggml-cpu/arch/x86/ (new file)
deferred CUDA_Quantize    -- see: ggml-cuda/ (new file)
deferred ROCM_Quantize    -- see: ggml-rocm/ (new file)
deferred Vulkan_Quantize  -- see: ggml-vulkan/ (partially exists)
deferred ARM_NEON_Quantize  -- see: ggml-cpu/arch/arm/ (new file)
