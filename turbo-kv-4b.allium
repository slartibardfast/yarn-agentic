-- allium: 3
-- turbo-kv-4b.allium

-- Scope: TURBO_KV_4B KV cache quantization
-- Includes: Block layout, quantize, dequantize, vec_dot, RHT transform,
--   L2_norm, normalize, nearest_centroid, reconstruct_codebook, rescale
-- Excludes:
--   - SIMD implementations (AVX2, AVX512, SSE4.1, ARM) — implementation detail
--   - Vulkan shaders — implementation detail
--   - CUDA/ROCM backends — not yet implemented
--   - TURBO_2B/3B/4B/5B weight quantization — separate concern
--   - Custom codebook loading — extension point
--   - imatrix-weighted quantization — inactive path

-- ============================================================
-- External entities (managed by ggml/tensor system)
-- ============================================================

external entity Tensor {
    data: Set<Decimal>
    count: Integer
}

actor TensorSupplier {
    identified_by: Tensor
}

-- ============================================================
-- Value types
-- ============================================================

-- A quantized KV block: 128 float elements → 72 bytes
entity TurboBlock {
    norm: Decimal          -- L2 norm of original 128-elem vector
    inv_std: Decimal       -- CENT_MAX / max(|RHT(normalized)|)
    indices: Set<Integer>  -- 128 codebook indices, each in [0, 15]
}

-- ============================================================
-- Config
-- ============================================================

config {
    block_size: Integer = 128
    codebook_size: Integer = 16
    seed: Integer = 305419896  -- 0x12345678
    cent_max: Decimal = 2.7326
    reconstruction_rel_error: Decimal = 0.1  -- observed 0.083 for unit Gaussian; budget to 10%
}

-- ============================================================
-- Algorithm-level rules (distilled from scalar C reference)
-- ============================================================

rule L2_norm {
    when: L2_norm(data)

    let norm_sq = sum_of_squares(data)
    let result = sqrt(norm_sq)

    ensures: result >= 0.0
}

rule normalize {
    when: normalize(data, norm)

    requires: norm > 0.0

    let inv_norm = 1.0 / norm
    let result = scaled(data, inv_norm)

    ensures: L2_norm(result) = 1.0
}

rule rescale {
    when: rescale(data, norm)

    requires: norm >= 0.0

    let result = scaled(data, norm)

    ensures: L2_norm(result) = L2_norm(data) * norm
}

rule RHT_forward {
    when: RHT_forward(data, n, seed)

    requires: n > 0

    let n2 = floor_pow2(n)
    let with_signs = apply_sign_flip(data, n2, seed)
    let hadamarded = walsh_hadamard_transform(with_signs, n2)
    let result = scale(hadamarded, 1.0 / sqrt(n2), n2)

    ensures: result.length = n
}

rule RHT_inverse {
    when: RHT_inverse(data, n, seed)

    requires: n > 0

    let n2 = floor_pow2(n)
    let scaled_data = scale(data, 1.0 / sqrt(n2), n2)
    let hadamarded = walsh_hadamard_transform(scaled_data, n2)
    let result = apply_sign_flip(hadamarded, n2, seed)

    ensures: result.length = n
}

rule nearest_centroid {
    when: nearest_centroid(rotated_data, inv_std, codebook_entries)

    requires: codebook_entries.count > 0

    let scaled_data = scaled_vector(rotated_data, inv_std)
    let result = find_nearest(scaled_data, codebook_entries)

    ensures: result.count = rotated_data.count
}

rule reconstruct_codebook {
    when: reconstruct_codebook(block, codebook_entries)

    requires: codebook_entries.count > 0
    requires: block.count > 0
    requires: block.inv_std > 0.0

    let scale = 1.0 / block.inv_std
    let lut = scaled_codebook(codebook_entries, scale)
    let result = lookup_indices(block.indices, lut, block.count)

    ensures: result.count = block.count
}

-- ============================================================
-- Composite rules (orchestrate algorithm-level rules)
-- ============================================================

rule QuantizeBlock {
    when: QuantizeBlock(tensor, seed)

    requires: tensor.count = config.block_size
    -- Rejects the all-zero input. Rules this out for normalize (needs norm > 0)
    -- and for the cent_max / max_abs(rotated) division below; RHT is orthogonal,
    -- so max_abs(rotated) > 0 whenever L2_norm(tensor.data) > 0.
    requires: L2_norm(tensor.data) > 0.0

    let norm = L2_norm(tensor.data)
    let normalized = normalize(tensor.data, norm)
    let rotated = RHT_forward(normalized, config.block_size, config.seed)
    let max_val = max_abs(rotated)
    let inv_std = config.cent_max / max_val
    let indices = nearest_centroid(rotated, inv_std, turbo_kv_4b_codebook)

    ensures: TurboBlock.created(
        norm: norm,
        inv_std: inv_std,
        indices: indices
    )
}

rule DequantizeBlock {
    when: DequantizeBlock(block)

    requires: block.inv_std > 0.0

    let codebook_values = reconstruct_codebook(block, turbo_kv_4b_codebook)
    let dequant_rotated = RHT_inverse(codebook_values, config.block_size, config.seed)
    let reconstructed = rescale(dequant_rotated, block.norm)

    ensures: Tensor.created(
        data: reconstructed,
        count: config.block_size
    )
}

rule VectorDot {
    when: VectorDot(query, block)

    requires: query.count = config.block_size

    let q_rotated = RHT_forward(query.data, config.block_size, config.seed)
    let k_dequant = reconstruct_codebook(block, turbo_kv_4b_codebook)
    let dot_result = dot_product(q_rotated, k_dequant) * block.norm

    ensures: result = dot_result
}

-- ============================================================
-- Invariants
-- ============================================================

-- Holds for TurboBlocks whose pre-quantization input is near-Gaussian
-- after normalize + RHT — the operating domain TURBO_KV_4B targets
-- (kurtosis ~2.96 observed on Qwen3.5 KV; PHASE24 measured rel_err=0.083
-- on unit Gaussian). Adversarial inputs (one-hot, highly sparse) can
-- exceed the bound and are outside the operating domain.
invariant ReconstructionPreservesNorm {
    for block in TurboBlocks:
        let reconstructed = DequantizeBlock(block)
        abs(L2_norm(reconstructed.data) - block.norm) <= block.norm * config.reconstruction_rel_error
}

invariant RHTOrthogonality {
    for a in Tensors:
        for b in Tensors:
            let a_rot = RHT_forward(a.data, a.count, config.seed)
            let b_rot = RHT_forward(b.data, b.count, config.seed)
            dot_product(a_rot, b_rot) = dot_product(a.data, b.data)
}

invariant RHTIsSelfInverse {
    for v in Tensors:
        let rotated = RHT_forward(v.data, v.count, config.seed)
        let restored = RHT_inverse(rotated, v.count, config.seed)
        restored = v.data
}

invariant NearestCentroidMinimizesError {
    for x in ScaledValues:
        for cb in Codebooks:
            let best = find_nearest(x, cb.entries)
            for other in cb.entries:
                abs(x - best) <= abs(x - other)
}

invariant DeterministicSeed {
    config.seed = 305419896
}

invariant BlockSizeFixed {
    config.block_size = 128
}

invariant IndicesInBounds {
    for block in TurboBlocks:
        for idx in block.indices:
            idx >= 0 and idx < config.codebook_size
}

-- ============================================================
-- Implementation notes
-- ============================================================

-- The rule bodies above call helpers (sum_of_squares, sqrt, scaled,
-- scale, scaled_vector, scaled_codebook, find_nearest, lookup_indices,
-- floor_pow2, apply_sign_flip, walsh_hadamard_transform, dot_product,
-- max, max_abs, abs) as black-box functions. Their C reference lives
-- in llama.cpp/ggml/src/ggml-turbo-kv.c.
--
-- SIMD and backend implementations (AVX2, AVX-512, CUDA, ROCm, Vulkan,
-- ARM NEON) are outside the spec per the scope at the top of this file.
-- Any implementation must produce results identical to the scalar
-- reference path; PPL on the target model must match the CPU baseline.
