-- allium: 3
-- turbo-l2norm.allium
--
-- Scope: L2 norm computation for a vector.
-- Source: ggml-turbo-kv.c quantize_block_turbo_kv_4b step 1 (line 245-249)
--
-- Computes sqrt(sum(data[i]^2 for i in [0, n))).
-- Referenced by QuantizeBlock rule in turbo-kv-4b.allium.

rule L2_norm {
    when: L2_norm(data)

    let norm_sq = sum_of_squares(data)
    let result = sqrt(norm_sq)

    ensures: result >= 0.0
}

deferred sqrt -- black box: square root function
deferred sum_of_squares -- black box: sum of element-wise squares
