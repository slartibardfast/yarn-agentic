--   ik_llama.cpp/ggml/src/ggml-common.h    — block_q4_0_ar16 typedef
--   ik_llama.cpp/ggml/src/ggml-quants.{h,c} — quantize / dequantize / vec_dot
--   ik_llama.cpp/ggml/src/ggml.c           — type_traits[GGML_TYPE_Q4_0_AR16]
--
-- gguf-py reference (Phase 1.C):
--   ik_llama.cpp/gguf-py/gguf/quants.py    — Q4_0_AR16 numpy class
--
-- Tool 1 emit path (Phase 1.D):
--   /home/llm/yarn-agentic/scripts/autoround_to_q4_0_gguf.py
--     — repack_w4g128_with_v_col_perm helper, analogous to the
--       V-row-perm path that landed in Stage 1.
