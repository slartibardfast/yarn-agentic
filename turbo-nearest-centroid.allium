-- allium: 3
-- turbo-nearest-centroid.allium
--
-- Scope: Per-element nearest-centroid quantization using Lloyd-Max Gaussian codebook.
-- Source: ggml-turbo-kv.c quantize_block_turbo_kv_4b step 5 (line 277-293)
--
-- For each element x = rotated[i] * inv_std, find the codebook entry c
-- that minimizes |x - codebook[c]|.
-- Referenced by QuantizeBlock rule in turbo-kv-4b.allium.

entity Codebook {
    entries: Set<Decimal>
    size: Integer
}

entity QuantizedBlock {
    indices: Set<Integer>
    count: Integer
}

rule nearest_centroid {
    when: nearest_centroid(rotated_data, inv_std, codebook)

    requires: codebook.size > 0

    let scaled = scaled_vector(rotated_data, inv_std)
    let result = find_nearest(scaled, codebook.entries)

    ensures: QuantizedBlock.created(
        indices: result,
        count: rotated_data.count
    )
}

deferred scaled_vector -- see: ggml-turbo-kv.c quantize_block_turbo_kv_4b step 5 (x * inv_std)
deferred find_nearest -- see: ggml-turbo-kv.c quantize_block_turbo_kv_4b step 5 (argmin linear scan)
