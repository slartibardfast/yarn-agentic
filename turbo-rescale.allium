-- allium: 3
-- turbo-rescale.allium
--
-- Scope: Rescale dequantized vector by original L2 norm.
-- Source: ggml-turbo-kv.c dequantize_block_turbo_kv_4b step 3 (line 336-339)
--
-- dst[i] = rotated[i] * norm.
-- Referenced by DequantizeBlock rule in turbo-kv-4b.allium.

rule rescale {
    when: rescale(data, norm)

    let result = scaled(data, norm)

    ensures: L2_norm(result) = L2_norm(data) * norm
}

deferred scaled -- black box: element-wise multiplication by norm
