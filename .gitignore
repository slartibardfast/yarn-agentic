# Claude Code (self-referential agent state)
.claude/

# mdBook build output (generated by CI)
book/

# Editor / OS
*.swp
.DS_Store

# Build / run artefacts
*.log
__pycache__/
rapidcheck/
cuda-graph-probe-*/

# TLC counterexample trace dumps (auto-generated during model checking)
specs/**/*_TTrace_*.tla
specs/**/*_TTrace_*.bin

# TLA+ tooling (fetched per-host; CI re-downloads tla2tools.jar each run)
.tla-tools/

# GPU coordination state (volatile, per-host)
coord/

# PHASE46 B.8 — vision payload is reproducible from test-1.jpeg via
# scripts/gen-test-vision-payload.sh; do not commit the ~165 KB JSON.
scripts/test-vision-payload.json

# PHASE_CUDA_NATIVE_DISPATCH predesign — compiled microbench binaries
data/cuda-native-dispatch/predesign/pd2_capture
data/cuda-native-dispatch/predesign/pd5_nccl
data/cuda-native-dispatch/predesign/pd6_mstream
data/cuda-native-dispatch/predesign/pd5_result.json
data/cuda-native-dispatch/predesign/pd6_result.json

# Phase R3 nsys traces — too large for git (192 MB to 6.9 GB each).
# Local-only; raw .nsys-rep can be opened in nsys-ui if needed.
data/perf-r3-np1/**/*.nsys-rep
data/perf-r3-np1/**/*.sqlite
data/perf-r3-np1/**/*.qdstrm

# Profiling traces — global ignore. These are large binary outputs of
# nvidia tools (nsys, ncu). Previously committed traces under
# data/deltanet/ and data/ncu-singlewarp-*/ are kept as research
# artifacts from closed phases; this pattern prevents new traces from
# accidentally entering git. Use `git add -f` to override if a specific
# trace must be committed.
*.nsys-rep
*.sqlite
*.qdstrm
*.ncu-rep
